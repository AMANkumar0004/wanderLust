<script>

const fileInput = document.getElementById('images')
const fileCount = document.getElementById('fileCount')
const previews = document.getElementById('imagePreviews')

let allFiles = new DataTransfer()

fileInput.addEventListener('change', function(){

  Array.from(this.files).forEach(file=>{
    allFiles.items.add(file)
  })

  this.files = allFiles.files

  updateUI()

})


function updateUI(){

  fileCount.innerText = `Selected: ${allFiles.files.length} files`

  previews.innerHTML = ''

  Array.from(allFiles.files).forEach((file,index)=>{

    const reader = new FileReader()

    reader.onload = function(e){

      const div = document.createElement('div')

      div.className='col-3 mb-3 position-relative'

      div.innerHTML = `
        <img src="${e.target.result}" 
        class="img-thumbnail"
        style="height:100px;width:100%;object-fit:cover">

        <button type="button"
        class="btn btn-danger btn-sm position-absolute top-0 end-0 rounded-circle"
        style="transform:translate(25%,-25%)"
        onclick="removeFile(${index})">

        &times;
        </button>
      `

      previews.appendChild(div)

    }

    reader.readAsDataURL(file)

  })

}


window.removeFile = function(index){

  const dt = new DataTransfer()

  Array.from(allFiles.files).forEach((file,i)=>{
    if(i !== index) dt.items.add(file)
  })

  allFiles = dt

  fileInput.files = allFiles.files

  updateUI()

}

</script>
