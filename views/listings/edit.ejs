<%= layout("/layouts/boilerplate.ejs") %>

  <body>
    <div class="row">
      <div class="col-8 offset-2 mt-3">
        <h3>Edit your listing</h3>

        <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" novalidate class="needs-validation"
          enctype="multipart/form-data">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>

            <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required />
            <div class="invalid-feedback">Title is required</div>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required>
<%= listing.description %></textarea>
            <div class="invalid-feedback">Please add a short description</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Current Images</label>
            <p class="text-muted small mb-2">Click the ✕ on any image to mark it for deletion</p>
            <div class="row g-2" id="currentImagesRow">
              <% originalImages.forEach(function(img, index) { %>
                <div class="col-3 position-relative current-img-wrapper" id="img-<%= index %>">
                  <img src="<%= img.url %>" alt="Listing Image" class="img-thumbnail w-100"
                    style="height:100px; object-fit:cover; border-radius:8px; transition: opacity 0.2s, filter 0.2s;" />
                  <button type="button"
                    class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 delete-img-btn"
                    style="width:24px;height:24px;padding:0;line-height:1;transform:translate(25%,-25%);font-size:12px;"
                    onclick="markForDeletion(this, <%= index %>)">
                    &times;
                  </button>
                  <input type="checkbox" name="deleteImages[]" value="<%= img.filename || '' %>"
                    class="d-none delete-checkbox" />
                </div>
                <% }) %>
            </div>
          </div>

          <script>
            function markForDeletion(btn, index) {
              const wrapper = document.getElementById('img-' + index);
              const checkbox = wrapper.querySelector('.delete-checkbox');
              const img = wrapper.querySelector('img');
              if (checkbox.checked) {
                checkbox.checked = false;
                img.style.opacity = '1';
                img.style.filter = 'none';
                btn.innerHTML = '&times;';
                btn.classList.replace('btn-success', 'btn-danger');
              } else {
                checkbox.checked = true;
                img.style.opacity = '0.35';
                img.style.filter = 'grayscale(100%)';
                btn.innerHTML = '&#8631;';
                btn.classList.replace('btn-danger', 'btn-success');
              }
            }
          </script>


          <div class="mb-3">
            <label for="images" class="form-label">Upload New Images</label>
            <input type="file" name="listing[images]" class="form-control" id="images" multiple />
            <div class="form-text mt-2" id="newFileCount">Selected: 0 new files</div>
            <div id="newImagePreviews" class="row mt-2"></div>
          </div>

          <script>
            const fileInput = document.getElementById('images');
            const fileCount = document.getElementById('newFileCount');
            const previews = document.getElementById('newImagePreviews');
            let allFiles = new DataTransfer();

            fileInput.addEventListener('change', function (e) {
              // Add new files to our collection
              Array.from(this.files).forEach(file => {
                allFiles.items.add(file);
              });

              // Update the input field with the cumulative list
              this.files = allFiles.files;

              updateEditUI();
            });

            function updateEditUI() {
              fileCount.innerText = `Selected: ${allFiles.files.length} new files`;
              previews.innerHTML = '';

              Array.from(allFiles.files).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function (event) {
                  const div = document.createElement('div');
                  div.className = 'col-3 mb-3 position-relative';
                  div.innerHTML = `
                    <img src="${event.target.result}" class="img-thumbnail" style="height: 100px; width: 100%; object-fit: cover;">
                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 rounded-circle" 
                            onclick="removeEditFile(${index})" style="transform: translate(25%, -25%); width: 24px; height: 24px; padding: 0; line-height: 1;">
                      &times;
                    </button>
                  `;
                  previews.appendChild(div);
                }
                reader.readAsDataURL(file);
              });
            }

            window.removeEditFile = function (index) {
              const newDT = new DataTransfer();
              Array.from(allFiles.files).forEach((file, i) => {
                if (i !== index) newDT.items.add(file);
              });
              allFiles = newDT;
              fileInput.files = allFiles.files;
              updateEditUI();
            };
          </script>
          <div class="row">
            <div class="mb-3 col-md-4">
              <label for="price" class="form-label">Price</label>
              <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control" required />
              <div class="invalid-feedback">Price is required</div>
            </div>
            <div class="mb-3 col-md-8">
              <label for="country" class="form-label">Country</label>

              <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required />
              <div class="invalid-feedback">Country is required</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required />
            <div class="invalid-feedback">Location is required</div>
          </div>
          <br /><br />

          <select class="form-select" name="listing[category]" required>
            <option value="">Select Category</option>
            <option value="mountains">Mountains</option>
            <option value="arctic">Arctic</option>
            <option value="farms">Farms</option>
            <option value="rooms">Rooms</option>
            <option value="castles">Castles</option>
            <option value="cities">Cities</option>
            <option value="pools">Pools</option>
            <option value="beach">Beach</option>
            <option value="camping">Camping</option>
          </select>
          <br><br>
          <button class="btn btn-dark edit-btn mb-3">EDIT</button>
        </form>
      </div>
    </div>
  </body>