<% layout('/layouts/boilerplate') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Wishlist</h2>
    <span class="badge bg-dark fs-6">Points: <%= points %></span>
  </div>

  <% if (!wishlist || wishlist.length === 0) { %>
    <div class="alert alert-info" role="alert">
      You have no saved listings yet. <a href="/listings" class="alert-link">Explore listings</a> to start earning points.
    </div>
  <% } else { %>
    <div class="row">
      <% wishlist.forEach((item) => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow-sm">
            <img
              src="<%= item.image && item.image.url ? item.image.url : 'https://via.placeholder.com/400x250?text=No+Image' %>"
              class="card-img-top"
              alt="Wishlist listing image"
            />
            <div class="card-body">
              <h5 class="card-title"><%= item.title %></h5>
              <p class="card-text mb-1"><%= item.location %>, <%= item.country %></p>
              <% if (item.price) { %>
                <p class="card-text">&#x20B9; <%= item.price.toLocaleString('en-IN') %></p>
              <% } %>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
              <a class="btn btn-sm btn-outline-dark" href="/listings/<%= item._id %>">View</a>
              <form action="/wishlist/<%= item._id %>?_method=DELETE" method="POST" class="d-inline">
                <button class="btn btn-sm btn-outline-danger" aria-label="Remove from wishlist">Remove</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
